<%- include('partials/header') %>

    <div class="main-content">
        <h2>Recent Posts</h2>

        <% posts.forEach(post => { %>
        <div class="post-card">
            <div class="tags">
                <% post.tags.forEach(tag => { %>
                    <span class="tag"><%= tag %></span>
                <% }) %>
            </div>
            <h3 class="post-title"><%= post.title %></h3>
            <p><%= post.content %></p>
            <div class="post-meta">
                <span><%= post.author %></span>
                <span>· <%= post.date %></span>
            </div>
        </div>
    <% }) %>
    </div>

<%- include('partials/footer') %>